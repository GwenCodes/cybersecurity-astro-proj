---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const featured = posts.slice(0, 3);
---

<Layout title="Cybersecurity Hub">

  <!-- Hero Section -->
  <section class="min-h-screen flex items-center justify-center text-center px-4">
    <div class="max-w-3xl">
      
      <h1 class="text-4xl md:text-6xl font-bold mb-6">
        Cybersecurity Insights That Matter
      </h1>

      <p class="text-lg text-gray-600 mb-8">
        Learn practical security strategies, threat analysis, and tools to stay ahead in a digital world.
      </p>

      <div class="flex justify-center gap-4">
        <a href="/blog" class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700">
          Explore Articles
        </a>

        <a href="#" class="border px-6 py-3 rounded-lg hover:bg-gray-100">
          Subscribe
        </a>
      </div>

    </div>
  </section>

  <!-- Featured Articles -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-2xl font-semibold mb-8">Latest Articles</h2>

    <div class="grid md:grid-cols-3 gap-6">
      {featured.map(post => (
        <a href={`/blog/${post.slug}`} class="border rounded-xl p-4 hover:shadow-lg">
          <h3 class="text-xl font-bold mb-2">{post.data.title}</h3>
          <p class="text-gray-600">{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>

</Layout>