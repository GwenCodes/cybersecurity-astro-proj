---
// Navbar.astro
---

<header class="w-full border-b border-gray-800 bg-black">
  <nav class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6">

    <!-- Left: Logo + Brand -->
    <a href="/" class="flex items-center gap-3">
      <img 
        src="/cyber-brief-logo-corral.png"
        alt="Cyber-Brief logo"
        class="h-7 w-auto block"
      />
      <span class="text-white font-semibold text-lg tracking-tight">
        Cyber-Brief
      </span>
    </a>

    <!-- Right: Navigation Links -->
    <div class="flex items-center gap-8 text-sm font-medium text-slate-400">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <a href="/blog" class="hover:text-white transition-colors">Intelligence</a>
      <a href="/about" class="hover:text-white transition-colors">About</a>
    </div>

  </nav>
</header>
